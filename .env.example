CURSOR_ADMIN_API_KEY=your-cursor-key

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C0123456789

# Microsoft Teams — incoming webhook URL from a Power Automate
# "Post to a channel when a webhook request is received" workflow.
# Leave blank to disable Teams alerts.
TEAMS_WEBHOOK_URL=

DASHBOARD_URL=http://localhost:3000

SENDGRID_API_KEY=
SENDGRID_FROM=Cursor Tracker <alerts@yourcompany.com>
ALERT_EMAIL_TO=team-lead@yourcompany.com

CRON_SECRET=your-secret-for-cron-endpoint

# Authentication (optional - dashboard is open when AUTH_SECRET is not set)
# Setting AUTH_SECRET enables single-admin username/password sign-in
AUTH_SECRET=                               # openssl rand -base64 32
AUTH_ADMIN_USERNAME=admin                  # single admin username
AUTH_ADMIN_PASSWORD_HASH=                  # salted scrypt hash in "salt:hash" hex format
# Optional second user with readonly role (can view everything but cannot access /settings)
AUTH_READONLY_USERNAME=                    # e.g. viewer — leave blank to disable readonly user
AUTH_READONLY_PASSWORD_HASH=               # salted scrypt hash in "salt:hash" hex format
AUTH_TRUST_HOST=true                       # required when behind a reverse proxy (Fly.io, Vercel, etc.)
AUTH_URL=                                  # public URL, e.g. https://your-app.fly.dev (auto-detected locally)

ELEVENLABS_API_KEY=
